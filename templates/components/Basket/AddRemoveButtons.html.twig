{# <twig:c975LShop:Basket:AddRemoveButtons item="{{ item }}"/> #}
<div class="quantity-controls">
    <twig:c975LShop:Basket:DeleteButton type="{{ type }}" item="{{ item }}"/>
    <div>
        <twig:c975LShop:Basket:RemoveOneButton type="{{ type }}" item="{{ item }}"/>
        <span class="quantity lead" data-basket-target="itemQuantity" data-item-id="{{ type}}-{{ item.item.id }}">{{ quantity }}</span>
        <twig:c975LShop:Basket:AddOneButton type="{{ type }}" item="{{ item }}"/>
    </div>
</div>
